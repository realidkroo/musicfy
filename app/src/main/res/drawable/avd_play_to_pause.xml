<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector android:width="32dp" android:height="32dp" android:viewportWidth="24" android:viewportHeight="24">
            <group android:pivotX="12" android:pivotY="12" android:name="scale_group">
                <path
                    android:name="path_left"
                    android:pathData="M 8 6 L 8 18 L 13 15 L 13 9 Z"
                    android:fillColor="#ffffff"
                    android:strokeColor="#ffffff"
                    android:strokeWidth="6"
                    android:strokeLineJoin="round"
                    android:strokeLineCap="round"/>
                <path
                    android:name="path_right"
                    android:pathData="M 13 9 L 13 15 L 18 12 L 18 12 Z"
                    android:fillColor="#ffffff"
                    android:strokeColor="#ffffff"
                    android:strokeWidth="6"
                    android:strokeLineJoin="round"
                    android:strokeLineCap="round"/>
            </group>
        </vector>
    </aapt:attr>
    <target android:name="path_left">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M 8 6 L 8 18 L 13 15 L 13 9 Z"
                android:valueTo="M 7.5 6 L 7.5 18 L 7.5 18 L 7.5 6 Z"
                android:valueType="pathType"
                android:duration="400"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
    <target android:name="path_right">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="pathData"
                android:valueFrom="M 13 9 L 13 15 L 18 12 L 18 12 Z"
                android:valueTo="M 16.5 6 L 16.5 18 L 16.5 18 L 16.5 6 Z"
                android:valueType="pathType"
                android:duration="400"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
</animated-vector>
